{
  "description": "Gentler 5G profile for human-in-the-loop driving: same N-HiTS UL traffic source, but delays/jitter capped and the extreme outage removed so the link stays drivable. Control (uplink) + asymmetric camera (downlink). The harsher 5g_nhits_youtube_ul_scm_youtube_ul_smoke profile is for the autonomous latency-robustness sweeps.",
  "sample_period_s": 0.05,
  "duration_s": 60.0,
  "loop": true,
  "seed": 41,
  "channels": {
    "control": {
      "source": {
        "kind": "5g_repo_csv",
        "path": "../data/5g_generated/scm_youtube_ul_smoke/generated_traffic.csv",
        "direction": "UL_bitrate",
        "start_index": 0
      },
      "traffic_scale": 25.0,
      "base_delay_ms": 16.0,
      "jitter_ms": 2.0,
      "min_delay_ms": 4.0,
      "max_delay_ms": 140.0,
      "capacity_bps": 9000000.0,
      "queue_gain_ms": 10.0,
      "segments": [
        {"start_s": 0.0, "end_s": 12.0, "regime": "good"},
        {"start_s": 12.0, "end_s": 20.0, "regime": "poor", "extra_ms": 30.0},
        {"start_s": 20.0, "end_s": 60.0, "regime": "nominal"}
      ]
    },
    "manual": {"copy_from": "control"},
    "camera": {"copy_from": "control", "scale": 1.3, "offset_ms": 8.0}
  }
}
